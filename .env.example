OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
JARVIS_SYSTEM_PROMPT=

# Local Hermes/Erik bridge. Defaults are for Roel's local Hermes setup.
HERMES_PROFILE_COMMAND=cmo
HERMES_PROFILE_NAME=cmo
HERMES_TOOLSETS=safe
HERMES_BRIDGE_TIMEOUT_MS=180000
# Set to 1 to use the local demo response instead of Hermes.
HERMES_BRIDGE_DISABLED=0

# Optional. Leave empty to keep demo/browser speech mode.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
